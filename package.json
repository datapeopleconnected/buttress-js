{
  "name": "@buttress/buttress-js",
  "type": "module",
  "version": "3.0.0-5",
  "description": "The federated real-time open data platform",
  "author": "Data People Connected LTD",
  "license": "AGPL-3.0-or-later",
  "private": true,
  "engines": {
    "node": ">=24.15"
  },
  "main": "deploy/app.js",
  "scripts": {
    "docs": "npx docsify serve ./docs",
    "test": "npm run build && npm run test:unit && npm run test:e2e",
    "test:unit": "NODE_ENV=test mocha --timeout ${MOCHA_UNIT_TIMEOUT:-2000} --recursive --parallel test/unit/**/*",
    "test:e2e": "NODE_ENV=test node test/before-e2e.js && echo \"Running BJS in Install Mode.\" && NODE_ENV=test INSTALL_MODE=true ./bin/app.sh && echo \"Install Complete.\\n\"&& NODE_ENV=test TEST_ENV=e2e mocha --timeout ${MOCHA_E2E_TIMEOUT:-2000} --recursive --bail --no-node-snapshot test/e2e/index.test.js",
    "test:e2e:timed": "BJS_TIMING=1 BJS_TIMING_OUTPUT=${BJS_TIMING_OUTPUT:-test/perf/current.json} npm run test:e2e",
    "perf:baseline:record": "BJS_TIMING=1 BJS_TIMING_OUTPUT=test/perf/baseline.json npm run test:e2e",
    "perf:compare": "node test/perf/compare-timings.mjs --warn-pct 20 --fail-pct 35 --min-abs-ms 50",
    "clean": "rm -rf dist/*",
    "build": "npm run clean && npm run build-ts && npm run build-non-ts",
    "build-ts": "tsc",
    "build-non-ts": "copyfiles -V -u 1 'src/**/*.!(ts)' dist",
    "watch": "npm run clean && npm run watch-non-ts & npm run watch-ts",
    "watch-ts": "tsc -w",
    "watch-non-ts": "copyfiles -V -u 1 'src/**/*.!(ts)' dist --watch",
    "lint": "eslint ./src",
    "lint:fix": "eslint ./src --fix",
    "format": "prettier --check ./src",
    "format:fix": "prettier --write ./src",
    "coverage": "c8 npm run test",
    "start": "bin/buttress.sh",
    "licence-check": "./.husky/licence-check",
    "check": "tsc --noEmit && npm run lint && npm run format && npm run licence-check",
    "docker:build": "docker build -t buttress .",
    "docker:build-token": "npm run docker:build -- --build-arg NPM_TOKEN=${NPM_TOKEN}",
    "docker:run": "docker-compose -f .docker/docker-compose.yml up",
    "docker:run-full": "docker-compose -f .docker/docker-compose.full.yml up",
    "prepare": "husky install && [ -f ./.husky/nvm-fix ] && ./.husky/nvm-fix || true",
    "nvm": "~/.nvm/nvm-exec which node | xargs -I {} bash -c 'ln -sf \"{}\" ./.nvm-node' && chmod +x ./.nvm-node"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/datapeopleconnected/buttress-js.git"
  },
  "bugs": {
    "url": "https://github.com/datapeopleconnected/buttress-js/issues"
  },
  "dependencies": {
    "@buttress/api": "3.0.0-52",
    "@buttress/snippets": "1.0.0-31",
    "@dpc/node-env-obj": "npm:@jsr/dpc__node-env-obj@^0.3.3",
    "@hashgraph/sdk": "^2.81.0",
    "@redis/client": "^5.12.1",
    "@socket.io/redis-adapter": "^8.3.0",
    "@socket.io/redis-emitter": "~5.1.0",
    "bson": "^7.2.0",
    "express": "~5.2.1",
    "isolated-vm": "~6.1.2",
    "method-override": "~3.0.0",
    "mongodb": "^7.2.0",
    "morgan": "~1.10.1",
    "node-polyfill-webpack-plugin": "2.0.1",
    "object-hash": "~3.0.0",
    "on-finished": "~2.4.1",
    "pug": "~3.0.4",
    "puppeteer": "^25.0.4",
    "randomstring": "~1.3.1",
    "socket.io": "~4.8.3",
    "socket.io-client": "~4.8.3",
    "stream-json": "^2.1.0",
    "sugar": "~2.0.6",
    "sugar-inflections": "~2.0.6",
    "uuid": "~14.0.0",
    "webpack": "~5.106.2",
    "winston": "~3.19.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@types/node-redis-pubsub": "^3.0.4",
    "c8": "^11.0.0",
    "copyfiles": "^2.4.1",
    "eslint": "^10.3.0",
    "husky": "^9.1.7",
    "mocha": "^11.7.5",
    "prettier": "^3.8.3",
    "source-map-support": "^0.5.21",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.30.1"
  }
}
