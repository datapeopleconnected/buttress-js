{
  "name": "working-date",
  "version": "1",
  "selection": {
    "grade": {
      "@eq": 1
    }
  },
  "config": [
    {
      "verbs": [
        "GET"
      ],
      "schema": [
        "organisation"
      ],
      "env": {
        "startDate": "01/01/2022",
        "endDate": "31/01/2042"
      },
      "condition": {
        "@and": [
          {
            "#env.startDate": {
              "@gtDate": "#env.date.now"
            }
          },
          {
            "#env.endDate": {
              "@ltDate": "#env.date.now"
            }
          }
        ]
      },
      "query": {
        "access": "%FULL_ACCESS%"
      }
    }
  ]
}