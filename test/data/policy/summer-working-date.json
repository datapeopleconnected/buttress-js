{
  "name": "summer-working-date",
  "version": 1,
  "priority": 1,
  "merge": true,
  "selection": {
    "grade": {
      "@eq": 6
    }
  },
  "env": {
    "startDate": "01/07/2022"
  },
  "config": [
    {
      "verbs": [
        "GET"
      ],
      "schema": [
        "organisation"
      ],
      "env": {
        "endDate": "31/01/2042"
      },
      "condition": {
        "@and": [
          {
            "#env.startDate": {
              "@gtDate": "#env.date.now"
            }
          },
          {
            "#env.endDate": {
              "@ltDate": "#env.date.now"
            }
          }
        ]
      },
      "query": {
        "access": "%FULL_ACCESS%"
      }
    }
  ]
}