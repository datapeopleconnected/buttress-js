{
  "compilerOptions": {
    "target": "ES2023",
    "module": "node18",
    "lib": ["ES2023", "ESNext.AsyncIterable", "DOM.Iterable"],
    "moduleResolution": "node16",
    "resolveJsonModule": true,
    "noImplicitAny": false,
    "noEmitOnError": true,
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "outDir": "dist",
    "sourceMap": true,
    "inlineSources": false,
    "rootDir": "./src",
    "allowJs": true,
    "checkJs": false,
    "skipLibCheck": true
  },
  "include": ["./src/**/*"],
  "exclude": ["node_modules"]
}
